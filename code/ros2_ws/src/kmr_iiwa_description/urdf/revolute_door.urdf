<?xml version="1.0"?>
<!-- Revolute (hinged) door: frame + leaf (hinge) + lever handle (latch).
     Primitives only (box + cylinder). Import to USD in Isaac Sim.
     - Set door_frame as FIXED base link on import.
     - Tune resistance via the PhysX joint drive/damping after import
       (this is your "environment stiffness" to randomize).
     - Inertia values are placeholders; let Isaac Sim recompute from
       geometry + density if you prefer.
     Convention: door face normal = +X, width along +Y (hinge at Y=0),
     height along +Z. -->
<robot name="revolute_door">

  <!-- ===================== FRAME (static hinge post) ===================== -->
  <link name="door_frame">
    <visual>
      <origin xyz="0 -0.03 1.0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 2.0"/></geometry>
      <material name="frame_grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 -0.03 1.0" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 2.0"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.03 1.0"/>
      <mass value="50"/>
      <inertia ixx="16.7" iyy="16.7" izz="0.03" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ===================== DOOR LEAF ===================== -->
  <link name="door_leaf">
    <visual>
      <origin xyz="0.0 0.425 1.0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.85 2.0"/></geometry>
      <material name="door_wood"><color rgba="0.72 0.52 0.30 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.0 0.425 1.0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.85 2.0"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.0 0.425 1.0"/>
      <mass value="15"/>
      <inertia ixx="5.90" iyy="5.00" izz="0.91" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Hinge: vertical axis. This is what "opens". Kept locked by the
       latch-gating logic until the handle is turned past threshold. -->
  <joint name="hinge_joint" type="revolute">
    <parent link="door_frame"/>
    <child link="door_leaf"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.57" effort="200" velocity="2.0"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>

  <!-- ===================== HANDLE: spindle stub (rotates = latch) ======= -->
  <link name="handle_base">
    <visual>
      <origin xyz="0.02 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.04"/></geometry>
      <material name="handle_metal"><color rgba="0.2 0.2 0.22 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.02 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Latch: axis = door normal (X). Turn the handle here to unlock.
       Give it a spring-return via the PhysX drive after import. -->
  <joint name="latch_joint" type="revolute">
    <parent link="door_leaf"/>
    <child link="handle_base"/>
    <origin xyz="0.02 0.72 1.0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.7" effort="20" velocity="3.0"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <!-- ===================== HANDLE: lever to grasp ===================== -->
  <link name="handle_lever">
    <visual>
      <origin xyz="0 0.06 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.014" length="0.12"/></geometry>
      <material name="handle_metal"><color rgba="0.2 0.2 0.22 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0.06 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.014" length="0.12"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.06 0"/>
      <mass value="0.2"/>
      <inertia ixx="2.5e-4" iyy="1e-4" izz="2.5e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Attach the gripper HERE (surface gripper / fixed joint on contact). -->
  <joint name="handle_fixed" type="fixed">
    <parent link="handle_base"/>
    <child link="handle_lever"/>
    <origin xyz="0.04 0 0" rpy="0 0 0"/>
  </joint>

</robot>
