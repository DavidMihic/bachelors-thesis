<?xml version="1.0"?>
<!-- Sliding door: static rail + leaf (prismatic) + fixed pull handle.
     Primitives only (box + cylinder). Import to USD in Isaac Sim.
     - Set slide_frame as FIXED base link on import.
     - Tune resistance via the PhysX joint drive/damping after import
       (this is your "environment stiffness" to randomize).
     Convention: door face normal = +X, slide direction along +Y,
     height along +Z. No latch (handle is rigid).
     Handle diameter unified to 28mm (same as revolute_door's handle_lever)
     for a single gripper geometry across both door types. The grip bar is
     no longer floating in space - it's connected to the door face by two
     26mm standoff rods (top + bottom), like a real bar/pull handle. -->
<robot name="sliding_door">

  <!-- ===================== RAIL / FRAME (static) ===================== -->
  <link name="slide_frame">
    <visual>
      <origin xyz="0 0.9 2.05" rpy="0 0 0"/>
      <geometry><box size="0.06 2.0 0.06"/></geometry>
      <material name="frame_grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0.9 2.05" rpy="0 0 0"/>
      <geometry><box size="0.06 2.0 0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.9 2.05"/>
      <mass value="30"/>
      <inertia ixx="10" iyy="0.02" izz="10" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ===================== DOOR LEAF ===================== -->
  <link name="door_leaf">
    <visual>
      <origin xyz="0 0.425 1.0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.85 2.0"/></geometry>
      <material name="door_wood"><color rgba="0.72 0.52 0.30 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0.425 1.0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.85 2.0"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.425 1.0"/>
      <mass value="15"/>
      <inertia ixx="5.90" iyy="5.00" izz="0.91" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Slide: horizontal prismatic axis (Y). This is what "opens". -->
  <joint name="slide_joint" type="prismatic">
    <parent link="slide_frame"/>
    <child link="door_leaf"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.8" effort="200" velocity="1.0"/>
    <dynamics damping="8.0" friction="2.0"/>
  </joint>

  <!-- ===================== FIXED PULL HANDLE (drska) ===================== -->
  <!-- Vertical grip bar (radius 0.014 = 28mm dia, same as revolute door's
       handle_lever) standing off the door face along +X, held by two
       horizontal standoff rods (radius 0.013 = 26mm dia) connecting it to
       the door surface at local x=0 (= door_leaf front face, since this
       link's own origin coincides with the handle_fixed joint origin
       below). All three cylinders are collision-enabled primitives on the
       SAME rigid link (handle) - physically one welded assembly, no need
       for separate links/joints between grip bar and standoffs. -->
  <link name="handle">
    <!-- grip bar: vertical (default cylinder axis = local Z), centered on
         the handle_fixed joint height, offset 0.07m out from the door -->
    <visual>
      <origin xyz="0.07 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.014" length="0.25"/></geometry>
      <material name="handle_metal"><color rgba="0.2 0.2 0.22 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.07 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.014" length="0.25"/></geometry>
    </collision>

    <!-- top standoff rod: horizontal (rotated Z->X), door face (x=0) to
         grip bar center (x=0.07), near the top end of the grip bar -->
    <visual>
      <origin xyz="0.035 0 0.10" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.07"/></geometry>
      <material name="handle_metal"><color rgba="0.2 0.2 0.22 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.035 0 0.10" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.07"/></geometry>
    </collision>

    <!-- bottom standoff rod: same as above, mirrored to the bottom end -->
    <visual>
      <origin xyz="0.035 0 -0.10" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.07"/></geometry>
      <material name="handle_metal"><color rgba="0.2 0.2 0.22 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.035 0 -0.10" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.07"/></geometry>
    </collision>

    <!-- Combined placeholder inertial for all three pieces (one welded
         steel-tube assembly); as with the rest of this file, let Isaac Sim
         recompute from geometry + density if you prefer. -->
    <inertial>
      <origin xyz="0.07 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="1.7e-3" iyy="1.7e-3" izz="3.5e-5" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="handle_fixed" type="fixed">
    <parent link="door_leaf"/>
    <child link="handle"/>
    <origin xyz="0.02 0.65 1.0" rpy="0 0 0"/>
  </joint>

</robot>
